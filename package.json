{
  "name": "tack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:demo": "bun run --cwd apps/demo-client dev",
    "build:demo": "bun run --cwd apps/demo-client build",
    "demo:cli": "bun scripts/demo-cli.ts",
    "demo:story": "bun scripts/demo-cli.ts run",
    "demo:walkthrough": "bun scripts/demo-walkthrough.ts",
    "show:autonomous-loop": "bun scripts/show-autonomous-loop.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "verify:real-ots-corpus": "bun scripts/verify-real-ots-corpus.ts",
    "check": "bun run typecheck && bun test"
  },
  "dependencies": {
    "@scure/base": "^1.2.6",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
